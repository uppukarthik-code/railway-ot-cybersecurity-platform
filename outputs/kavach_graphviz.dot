				ops_workstation [label="Operations Workstation
[operations_workstation]" color="#222222" fillcolor="#6aa84f" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				maint_workstation -> ops_workstation [style=invis weight=10]
				ops_tms [label="Traffic Management System
[tms]" color="#222222" fillcolor="#6aa84f" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				ops_workstation -> ops_tms [style=invis weight=10]
			}
