digraph Railway_OT {
	bgcolor=white compound=true concentrate=false newrank=true nodesep=0.8 overlap=false pad=0.5 rankdir=TB ranksep=1.2 splines=ortho
	node [fontname=Arial fontsize=10 shape=box style="rounded,filled"]
	edge [fontname=Arial fontsize=8]
	subgraph cluster_onboard {
		color="#8e7cc3" fillcolor="#8e7cc322" label="Onboard Domain" margin=8 penwidth=3 style="rounded,dashed,filled"
		brake_interface_unit [label="Brake Interface Unit
[brake_interface_unit]" color="#CC0000" fillcolor="#8e7cc3" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
		driver_machine_interface [label="Driver Machine Interface
[driver_machine_interface]" color="#CC0000" fillcolor="#8e7cc3" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
		l_kavach [label="Locomotive Kavach
[l_kavach]" color="#CC0000" fillcolor="#8e7cc3" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
		onboard_rfid_reader [label="Onboard RFID Reader
[onboard_rfid_reader]" color="#222222" fillcolor="#8e7cc3" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
		speed_sensor [label="Speed Sensor
[speed_sensor]" color="#CC0000" fillcolor="#8e7cc3" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
		train_radio [label="Train Radio
[train_radio]" color="#222222" fillcolor="#8e7cc3" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
	}
	subgraph cluster_0 {
		color="#1f4e79" fillcolor="#1f4e7922" fontname="Arial Bold" fontsize=18 label="L5 Enterprise" margin=24 style="rounded,filled"
		rank=same
		subgraph cluster_0_0 {
			color="#d9e2f3" fontsize=12 label=enterprise_it margin=16 style="rounded,dashed"
			subgraph cluster_000 {
				color=lightgray fillcolor="#d9e2f3" fontsize=10 label="Enterprise Services" margin=10 style="rounded,filled"
				ent_email_server [label="Corporate Email Server
[enterprise_server]" color="#222222" fillcolor="#1f4e79" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				ent_eam_server [label="Enterprise Asset Management
[enterprise_server]" color="#222222" fillcolor="#1f4e79" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				ent_email_server -> ent_eam_server [style=invis weight=10]
				ent_erp_server [label="ERP System
[enterprise_server]" color="#222222" fillcolor="#1f4e79" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				ent_eam_server -> ent_erp_server [style=invis weight=10]
			}
		}
	}
	subgraph cluster_2 {
		color="#c00000" fillcolor="#c0000022" fontname="Arial Bold" fontsize=18 label="L3.5 IDMZ" margin=24 style="rounded,filled"
		rank=same
		subgraph cluster_2_0 {
			color="#f4cccc" fontsize=12 label=idmz margin=16 style="rounded,dashed"
			subgraph cluster_200 {
				color=lightgray fillcolor="#EEEEEE" fontsize=10 label="External Security Services" margin=10 style="rounded,filled"
				idmz_data_diode [label="Data Diode
[data_diode]" color="#222222" fillcolor="#c00000" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				idmz_firewall [label="IDMZ Firewall
[firewall]" color="#222222" fillcolor="#c00000" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				idmz_data_diode -> idmz_firewall [style=invis weight=10]
				idmz_jump_host [label="Jump Host
[jump_host]" color="#222222" fillcolor="#c00000" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				idmz_firewall -> idmz_jump_host [style=invis weight=10]
				idmz_vpn_gateway [label="VPN Gateway
[vpn_gateway]" color="#222222" fillcolor="#c00000" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				idmz_jump_host -> idmz_vpn_gateway [style=invis weight=10]
			}
		}
	}
	subgraph cluster_3 {
		color="#e06666" fillcolor="#e0666622" fontname="Arial Bold" fontsize=18 label="L3.5 Security" margin=24 style="rounded,filled"
		rank=same
