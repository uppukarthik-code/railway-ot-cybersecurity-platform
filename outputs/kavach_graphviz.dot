			}
		}
		subgraph cluster_3_1 {
			color="#ea9999" fontsize=12 label=security_management margin=16 style="rounded,dashed"
			subgraph cluster_310 {
				color=lightgray fillcolor="#EEEEEE" fontsize=10 label="Security Management" margin=10 style="rounded,filled"
				sec_ids_sensor [label="IDS Sensor
[ids_sensor]" color="#222222" fillcolor="#e06666" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				sec_ips_sensor [label="IPS Sensor
[ips_sensor]" color="#222222" fillcolor="#e06666" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				sec_ids_sensor -> sec_ips_sensor [style=invis weight=10]
				sec_siem [label="SIEM
[siem]" color="#222222" fillcolor="#e06666" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				sec_ips_sensor -> sec_siem [style=invis weight=10]
				sec_soc_server [label="SOC Server
[soc_server]" color="#222222" fillcolor="#e06666" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				sec_siem -> sec_soc_server [style=invis weight=10]
				sec_vuln_scanner [label="Vulnerability Scanner
[vulnerability_scanner]" color="#222222" fillcolor="#e06666" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				sec_soc_server -> sec_vuln_scanner [style=invis weight=10]
			}
		}
