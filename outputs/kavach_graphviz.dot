	subgraph cluster_5 {
		color="#3d85c6" fillcolor="#3d85c622" fontname="Arial Bold" fontsize=18 label="L2 Telecom" margin=24 style="rounded,filled"
		rank=same
		subgraph cluster_5_0 {
			color="#cfe2f3" fontsize=12 label=telecom_core margin=16 style="rounded,dashed"
			subgraph cluster_500 {
				color=lightgray fillcolor="#EEEEEE" fontsize=10 label="Telecom Network" margin=10 style="rounded,filled"
				telecom_mpls_router [label="MPLS Router
[mpls_router]" color="#222222" fillcolor="#3d85c6" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				telecom_gateway [label="Telecom Gateway
[telecom_gateway]" color="#222222" fillcolor="#3d85c6" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				telecom_mpls_router -> telecom_gateway [style=invis weight=10]
			}
