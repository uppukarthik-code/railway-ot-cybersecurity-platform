			color="#f9cb9c" fontsize=12 label=field margin=16 style="rounded,dashed"
			subgraph cluster_900 {
				color=lightgray fillcolor="#EEEEEE" fontsize=10 label="Field Equipment" margin=10 style="rounded,filled"
