[nms]" color="#222222" fillcolor="#6aa84f" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
				eng_workstation -> ops_nms [style=invis weight=10]
				maint_workstation [label="Maintenance Workstation
[operations_workstation]" color="#222222" fillcolor="#6aa84f" fontname=Arial fontsize=10 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
