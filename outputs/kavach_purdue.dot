	l3_operations_anchor -> ops_tms [style=invis weight=20]
	subgraph cluster_l2 {
		color="#999999" fillcolor="#F8F8F8" fontname="Arial Bold" fontsize=18 label=L2 margin=24 penwidth=2 style="rounded,filled"
		{
			rank=same
			subgraph cluster_l2_telecom {
				color="#D9EAD3" fillcolor="#D9EAD322" fontsize=15 label="L2 Telecom" margin=18 penwidth=2 style="rounded,filled"
				{
					rank=same
					telecom_mpls_router [label="MPLS Router
[mpls_router]" color="#444444" fillcolor="#D9EAD3" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
					telecom_gateway [label="Telecom Gateway
[telecom_gateway]" color="#444444" fillcolor="#D9EAD3" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
					telecom_mpls_router -> telecom_gateway [constraint=false style=invis weight=5]
				}
			}
			subgraph cluster_l2_interlocking {
				color="#F4CCCC" fillcolor="#F4CCCC22" fontsize=15 label="L2 Interlocking" margin=18 penwidth=2 style="rounded,filled"
				{
					rank=same
					s_kavach [label="Stationary Kavach
[s_kavach]" color="#7A3DB8" fillcolor="#F4CCCC" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
					electronic_interlocking [label="Electronic Interlocking
[electronic_interlocking]" color="#444444" fillcolor="#F4CCCC" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
					s_kavach -> electronic_interlocking [constraint=false style=invis weight=5]
				}
			}
		}
	}
	l2_anchor -> telecom_mpls_router [style=invis weight=20]
	subgraph cluster_l1 {
		color="#999999" fillcolor="#F8F8F8" fontname="Arial Bold" fontsize=18 label=L1 margin=24 penwidth=2 style="rounded,filled"
		{
			rank=same
			subgraph cluster_l1_telecom {
				color="#B6D7A8" fillcolor="#B6D7A822" fontsize=15 label="L1 Telecom" margin=18 penwidth=2 style="rounded,filled"
				{
					rank=same
					radio_base_station [label="Railway Radio Base Station
[railway_radio_base_station]" color="#7A3DB8" fillcolor="#B6D7A8" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,dashed,filled" width=2.4]
					radio_gateway [label="Radio Gateway
[radio_gateway]" color="#7A3DB8" fillcolor="#B6D7A8" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,dashed,filled" width=2.4]
					radio_base_station -> radio_gateway [constraint=false style=invis weight=5]
				}
			}
			subgraph cluster_l1_interlocking {
				color="#EA9999" fillcolor="#EA999922" fontsize=15 label="L1 Interlocking" margin=18 penwidth=2 style="rounded,filled"
				{
					rank=same
					axle_counter_evaluator [label="Axle Counter Evaluator
[axle_counter_evaluator]" color="#444444" fillcolor="#EA9999" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
					object_controller [label="Object Controller
[object_controller]" color="#444444" fillcolor="#EA9999" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
					axle_counter_evaluator -> object_controller [constraint=false style=invis weight=5]
				}
			}
		}
	}
	l1_anchor -> radio_base_station [style=invis weight=20]
	subgraph cluster_l0_field {
		color="#E2F0D9" fillcolor="#E2F0D922" fontname="Arial Bold" fontsize=18 label="L0 Field" margin=24 penwidth=2 style="rounded,filled"
		{
			rank=same
			point_machine_controller [label="Point Machine Controller
[point_machine_controller]" color="#444444" fillcolor="#E2F0D9" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
			signal_controller [label="Signal Controller
[signal_controller]" color="#444444" fillcolor="#E2F0D9" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
			point_machine_controller -> signal_controller [constraint=false style=invis weight=5]
			track_circuit [label="Track Circuit
[track_circuit]" color="#444444" fillcolor="#E2F0D9" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
			signal_controller -> track_circuit [constraint=false style=invis weight=5]
			axle_counter_head [label="Axle Counter Head
