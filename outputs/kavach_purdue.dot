digraph RailwayPurdue {
	bgcolor=white compound=true concentrate=false newrank=true nodesep=1.0 overlap=false pad=0.4 rankdir=TB ranksep="2.0 equally" splines=ortho
	node [fontname=Arial]
	edge [fontname=Arial]
	l5_enterprise_anchor [label="" height=0.01 shape=point style=invis width=0.01]
	l4_business_anchor [label="" height=0.01 shape=point style=invis width=0.01]
	l5_enterprise_anchor -> l4_business_anchor [style=invis weight=100]
	l35_idmz_anchor [label="" height=0.01 shape=point style=invis width=0.01]
	l4_business_anchor -> l35_idmz_anchor [style=invis weight=100]
	l35_security_anchor [label="" height=0.01 shape=point style=invis width=0.01]
	l35_idmz_anchor -> l35_security_anchor [style=invis weight=100]
	l3_operations_anchor [label="" height=0.01 shape=point style=invis width=0.01]
	l35_security_anchor -> l3_operations_anchor [style=invis weight=100]
	l2_anchor [label="" height=0.01 shape=point style=invis width=0.01]
	l3_operations_anchor -> l2_anchor [style=invis weight=100]
	l1_anchor [label="" height=0.01 shape=point style=invis width=0.01]
	l2_anchor -> l1_anchor [style=invis weight=100]
	l0_field_anchor [label="" height=0.01 shape=point style=invis width=0.01]
	l1_anchor -> l0_field_anchor [style=invis weight=100]
	subgraph cluster_onboard {
		color="#7A3DB8" fillcolor="#F3E8FF" label="Mobile Onboard Domain" penwidth=3 style="rounded,dashed,filled"
		{
			rank=same
			l_kavach [label="Locomotive Kavach
[l_kavach]" color="#7A3DB8" fillcolor="#D9C2E9" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
			train_radio [label="Train Radio
[train_radio]" color="#7A3DB8" fillcolor="#D9C2E9" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
			driver_machine_interface [label="Driver Machine Interface
[driver_machine_interface]" color="#444444" fillcolor="#D9C2E9" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
			brake_interface_unit [label="Brake Interface Unit
[brake_interface_unit]" color="#444444" fillcolor="#D9C2E9" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
			speed_sensor [label="Speed Sensor
[speed_sensor]" color="#444444" fillcolor="#D9C2E9" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
			onboard_rfid_reader [label="Onboard RFID Reader
[onboard_rfid_reader]" color="#444444" fillcolor="#D9C2E9" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
		}
	}
	l0_field_anchor -> l_kavach [constraint=true style=invis weight=5]
	subgraph cluster_external_security {
		color="#AA4444" fillcolor="#FDE9E7" fontname="Arial Bold" fontsize=18 label="External Security Services" margin=20 penwidth=3 style="rounded,dashed,filled"
		{
			rank=same
			ext_kms_server [label="External KMS Server
[external_kms_server]" color="#444444" fillcolor="#FFF2CC" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,dashed,filled" width=2.4]
		}
	}
	l35_security_anchor -> ext_kms_server [constraint=true style=invis weight=5]
	subgraph cluster_l5_enterprise {
		color="#DCE6F1" fillcolor="#DCE6F122" fontname="Arial Bold" fontsize=18 label="L5 Enterprise" margin=24 penwidth=2 style="rounded,filled"
		{
			rank=same
			ent_email_server [label="Corporate Email Server
[enterprise_server]" color="#444444" fillcolor="#DCE6F1" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,dashed,filled" width=2.4]
			ent_erp_server [label="ERP System
[enterprise_server]" color="#444444" fillcolor="#DCE6F1" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,dashed,filled" width=2.4]
			ent_email_server -> ent_erp_server [constraint=false style=invis weight=5]
			ent_eam_server [label="Enterprise Asset Management
[enterprise_server]" color="#444444" fillcolor="#DCE6F1" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,dashed,filled" width=2.4]
			ent_erp_server -> ent_eam_server [constraint=false style=invis weight=5]
		}
	}
	l5_enterprise_anchor -> ent_email_server [style=invis weight=20]
	subgraph cluster_l35_idmz {
		color="#FCE5CD" fillcolor="#FCE5CD22" fontname="Arial Bold" fontsize=18 label="L3.5 IDMZ" margin=24 penwidth=2 style="rounded,filled"
		{
			rank=same
			idmz_firewall [label="IDMZ Firewall
[firewall]" color="#444444" fillcolor="#FCE5CD" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,dashed,filled" width=2.4]
			idmz_vpn_gateway [label="VPN Gateway
[vpn_gateway]" color="#444444" fillcolor="#FCE5CD" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,dashed,filled" width=2.4]
			idmz_firewall -> idmz_vpn_gateway [constraint=false style=invis weight=5]
			idmz_jump_host [label="Jump Host
[jump_host]" color="#444444" fillcolor="#FCE5CD" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,dashed,filled" width=2.4]
			idmz_vpn_gateway -> idmz_jump_host [constraint=false style=invis weight=5]
			idmz_data_diode [label="Data Diode
[data_diode]" color="#444444" fillcolor="#FCE5CD" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,dashed,filled" width=2.4]
			idmz_jump_host -> idmz_data_diode [constraint=false style=invis weight=5]
		}
	}
	l35_idmz_anchor -> idmz_firewall [style=invis weight=20]
	subgraph cluster_l35_security {
		color="#FFF2CC" fillcolor="#FFF2CC22" fontname="Arial Bold" fontsize=18 label="L3.5 Security" margin=24 penwidth=2 style="rounded,filled"
		{
			rank=same
			sec_siem [label="SIEM
[siem]" color="#444444" fillcolor="#FFF2CC" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
			sec_soc_server [label="SOC Server
[soc_server]" color="#444444" fillcolor="#FFF2CC" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
			sec_siem -> sec_soc_server [constraint=false style=invis weight=5]
			sec_ids_sensor [label="IDS Sensor
[ids_sensor]" color="#444444" fillcolor="#FFF2CC" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
			sec_soc_server -> sec_ids_sensor [constraint=false style=invis weight=5]
			sec_ips_sensor [label="IPS Sensor
[ips_sensor]" color="#444444" fillcolor="#FFF2CC" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
			sec_ids_sensor -> sec_ips_sensor [constraint=false style=invis weight=5]
			sec_vuln_scanner [label="Vulnerability Scanner
[vulnerability_scanner]" color="#444444" fillcolor="#FFF2CC" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
			sec_ips_sensor -> sec_vuln_scanner [constraint=false style=invis weight=5]
			ext_kms_server [label="External KMS Server
[external_kms_server]" color="#444444" fillcolor="#FFF2CC" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,dashed,filled" width=2.4]
			sec_vuln_scanner -> ext_kms_server [constraint=false style=invis weight=5]
		}
	}
	l35_security_anchor -> sec_siem [style=invis weight=20]
	subgraph cluster_l3_operations {
		color="#D9EAF7" fillcolor="#D9EAF722" fontname="Arial Bold" fontsize=18 label="L3 Operations" margin=24 penwidth=2 style="rounded,filled"
		{
			rank=same
			ops_tms [label="Traffic Management System
[tms]" color="#444444" fillcolor="#D9EAF7" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
			ops_nms [label="Network Management System
[nms]" color="#444444" fillcolor="#D9EAF7" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
			ops_tms -> ops_nms [constraint=false style=invis weight=5]
			ops_workstation [label="Operations Workstation
[operations_workstation]" color="#444444" fillcolor="#D9EAF7" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
			ops_nms -> ops_workstation [constraint=false style=invis weight=5]
			maint_workstation [label="Maintenance Workstation
[operations_workstation]" color="#444444" fillcolor="#D9EAF7" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
			ops_workstation -> maint_workstation [constraint=false style=invis weight=5]
			eng_workstation [label="Engineering Workstation
[engineering_workstation]" color="#444444" fillcolor="#D9EAF7" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,filled" width=2.4]
			maint_workstation -> eng_workstation [constraint=false style=invis weight=5]
		}
