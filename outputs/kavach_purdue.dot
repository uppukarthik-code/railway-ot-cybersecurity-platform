			track_circuit -> axle_counter_head [constraint=false style=invis weight=5]
			trackside_rfid_tag [label="Trackside RFID Tag
[trackside_rfid_tag]" color="#444444" fillcolor="#E2F0D9" fontname=Arial fontsize=15 height=0.9 penwidth=2 shape=box style="rounded,solid,filled" width=2.4]
			axle_counter_head -> trackside_rfid_tag [constraint=false style=invis weight=5]
